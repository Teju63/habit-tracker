{
  "info": {
    "name": "Smart Habit Tracker API",
    "description": "Postman collection for Team Vate — Smart Habit Streak Tracker API tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "vate-team"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001", "type": "string" },
    { "key": "habitId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health & Metrics",
      "item": [
        {
          "name": "Health Check",
          "request": { "method": "GET", "url": "{{baseUrl}}/health" },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Status healthy', () => { const b = pm.response.json(); pm.expect(b.status).to.equal('healthy'); });"
            ]}
          }]
        },
        {
          "name": "Prometheus Metrics",
          "request": { "method": "GET", "url": "{{baseUrl}}/metrics" },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Contains metrics', () => pm.expect(pm.response.text()).to.include('habits_total'));"
            ]}
          }]
        }
      ]
    },
    {
      "name": "Habits CRUD",
      "item": [
        {
          "name": "Create Habit",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/habits",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Morning Run\",\n  \"category\": \"health\",\n  \"frequency\": \"daily\",\n  \"target\": 30,\n  \"color\": \"#FF6B6B\",\n  \"userId\": \"test-user\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.test('Has id', () => { const b = pm.response.json(); pm.expect(b.data.id).to.be.a('string'); pm.collectionVariables.set('habitId', b.data.id); });"
            ]}
          }]
        },
        {
          "name": "Get All Habits",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/habits" },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Is array', () => { const b = pm.response.json(); pm.expect(b.data).to.be.an('array'); });"
            ]}
          }]
        },
        {
          "name": "Get Single Habit",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/habits/{{habitId}}" },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
          }]
        },
        {
          "name": "Update Habit",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/habits/{{habitId}}",
            "body": { "mode": "raw", "raw": "{ \"streak\": 7 }" }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Streak updated', () => { const b = pm.response.json(); pm.expect(b.data.streak).to.equal(7); });"
            ]}
          }]
        }
      ]
    },
    {
      "name": "Logs & Stats",
      "item": [
        {
          "name": "Toggle Log",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/logs/{{habitId}}/toggle",
            "body": { "mode": "raw", "raw": "{ \"date\": \"2026-04-05\" }" }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
          }]
        },
        {
          "name": "Get Stats",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/stats" },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Has totalHabits', () => { const b = pm.response.json(); pm.expect(b.data).to.have.property('totalHabits'); });"
            ]}
          }]
        }
      ]
    }
  ]
}
